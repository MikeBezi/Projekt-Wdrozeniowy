POSTGRES_USER=projekt_app
POSTGRES_PASSWORD=projekt_pass
POSTGRES_DB=projekt_wdrozeniowy
POSTGRES_PORT=5432

# Connection string dla backendu (z hosta, poza Dockerem):
# postgresql://projekt_app:projekt_pass@localhost:5432/projekt_wdrozeniowy

# Z innego kontenera w tej samej sieci Docker:
# postgresql://projekt_app:projekt_pass@postgres:5432/projekt_wdrozeniowy
